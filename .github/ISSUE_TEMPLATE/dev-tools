name: Developer Tools
description: Add a new WoT developer tool
title: '[Dev-Tool]: '
labels: ['issue-form']
body:
  - type: markdown
    attributes:
      value: Please fill out data about the tool you want to add to the developer tools list on the W3C WoT website
  - type: input
    attributes:
      label: Repository URL
      placeholder: https://github.com/organization/project-name
    validations:
      required: true
  - type: input
    attributes:
      label: Affiliation
      descriptioin: The organization, company, institution, or group the tool affiliates with
  - type: dropdown
    attributes:
      label: Automatically fetch data
      description: Weekly tools' data is fetched from their repositories. If you turn this on, all of the attributes below become optional to fill. You can still turn on automatical fetching and override specific attributes. For now only GitHub and GitLab are supported.
      default: 0
      options:
        - On
        - Off
    validations:
      required: true
  - type: input
    attributes:
      label: Tool Name
  - type: textarea
    attributes:
      label: Description
  - type: input
    attributes:
      label: Programming Languages
      description: Supported languages for the tool. If several, separate with commas.
  - type: input
    attributes:
      label: Homepage URL
